<!-- 
  Custom Wazuh Detection Rules
  Author: Jan Wojnicki & Iwo Sidorowicz
  Context: Purple Team Simulation (Assume Breach)
-->

<group name="local, syslog, sshd, windows, sysmon,">

  <!-- MITRE T1003.001: OS Credential Dumping - LSASS Memory -->
  <!-- Detects the usage of rundll32.exe combined with comsvcs.dll to dump process memory -->
  <rule id="100050" level="12">
    <if_group>sysmon_event1</if_group>
    <match>comsvcs.dll</match>
    <description>CRITICAL: Attempt to steal passwords from LSASS by rundll32.exe (LotL) - T1003.001</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
  </rule>

  <!-- MITRE T1490: Inhibit System Recovery (Ransomware Behavior) -->
  <!-- Utilizes Regex to catch "delete shadows" argument regardless of the binary (vssadmin/wmic) -->
  <rule id="100051" level="12">
    <if_group>windows</if_group>
    <match>delete shadows</match>
    <description>RANSOMWARE: Attempt to delete Volume Shadow Copies - T1490!</description>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

</group>
